{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@forgeid/db": ["../../packages/db/src"],
      "@forgeid/shared": ["../../packages/shared/src"],
      "@forgeid/sdk": ["../../packages/sdk/src"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
