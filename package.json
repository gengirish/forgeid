{
  "name": "forgeid",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @forgeid/api dev",
    "dev:dashboard": "pnpm --filter @forgeid/dashboard dev",
    "dev:mcp": "pnpm --filter @forgeid/mcp-server dev",
    "dev:all": "pnpm run --parallel dev:api dev:dashboard",
    "build:all": "pnpm run --recursive build",
    "db:generate": "pnpm --filter @forgeid/db generate",
    "db:push": "pnpm --filter @forgeid/db push",
    "db:migrate": "pnpm --filter @forgeid/db migrate",
    "db:studio": "pnpm --filter @forgeid/db studio",
    "test:e2e": "tsx test-e2e.ts",
    "lint": "pnpm run --recursive lint",
    "typecheck": "pnpm run --recursive typecheck"
  },
  "dependencies": {
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
